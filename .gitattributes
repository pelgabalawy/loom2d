# Normalize line endings. Keep shell scripts LF so they run on macOS/Linux,
# and keep PowerShell scripts CRLF for Windows.
* text=auto

*.sh   text eol=lf
*.ps1  text eol=crlf

# Source stays LF in the repo (Git converts on checkout per the host).
*.py   text
*.cpp  text
*.hpp  text
*.c    text
*.h    text
*.cmake text
*.md   text
*.toml text
*.json text
CMakeLists.txt text
